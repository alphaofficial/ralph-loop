#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "$0")" && pwd)/ralph-common.sh"

invoke_provider() {
  local provider="$1" target="$2" prompt_file="$3"
  if [[ -n "${RALPH_MODEL:-}" ]]; then
    (cd "$target" && codex exec --skip-git-repo-check --sandbox workspace-write --model "$RALPH_MODEL" "$(cat "$prompt_file")")
  else
    (cd "$target" && codex exec --skip-git-repo-check --sandbox workspace-write "$(cat "$prompt_file")")
  fi
}

target="$(pwd)"
max_loops="${RALPH_MAX_LOOPS:-8}"
check_cmd=""
dry_run=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --max-loops) max_loops="$2"; shift 2 ;;
    --check) check_cmd="$2"; shift 2 ;;
    --dry-run) dry_run=1; shift ;;
    -h|--help) usage_common "ralph-codex"; exit 0 ;;
    *) target="$1"; shift ;;
  esac
done
check_cmd="${check_cmd:-$(auto_detect_check "$target")}"
trap 'stop_spinner' EXIT
main_loop "codex" "$target" "$max_loops" "$check_cmd" "$dry_run"
